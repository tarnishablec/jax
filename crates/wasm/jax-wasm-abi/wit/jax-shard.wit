package jax:wit@0.1.0;

interface runtime {
  call-shard: func(shard-id: string, method: string, request-json: string) -> result<string, string>;
}

interface shard {
  record dependency {
    id: string,
  }

  record descriptor {
    id: string,
    label: string,
    dependencies: list<dependency>,
  }

  describe: func() -> descriptor;
  config-schema: func() -> string;
  configure: func(config: string) -> result<_, string>;
  setup: func() -> result<_, string>;
  teardown: func() -> result<_, string>;
}

world jax-shard {
  import runtime;
  export shard;
}
